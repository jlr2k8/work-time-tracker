# Trello API Configuration
# Get your API key from: https://trello.com/app-key
# Generate a token by visiting: https://trello.com/1/authorize?expiration=never&scope=read&response_type=token&name=WorkTimeTracker&key=YOUR_API_KEY
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_API_TOKEN=your_trello_api_token_here

# Trello Board ID (optional - can also be passed via command line)
# Found in your Trello board URL: https://trello.com/b/BOARD_ID/board-name
TRELLO_BOARD_ID=

# Trello Member ID (optional - for filtering cards assigned to you)
# You can find your member ID by visiting: https://api.trello.com/1/members/me?key=YOUR_API_KEY&token=YOUR_TOKEN
TRELLO_MEMBER_ID=

# Billing Configuration
HOURLY_RATE=80.0

# Excluded Cards (optional - comma-separated list of card numbers to exclude from invoices)
# Example: EXCLUDED_CARDS=102,103,104
EXCLUDED_CARDS=

# Invoice Sender Information
SENDER_NAME=Your Name
SENDER_ADDRESS=123 Main St, City, ST 12345
SENDER_PHONE=555-555-5555
SENDER_EMAIL=your.email@example.com

# Invoice Recipient Information
RECIPIENT_NAME=Client Name

# Invoice Number Prefix (e.g., "INV" will generate invoices like "INV-001", "INV-002")
INVOICE_PREFIX=INV