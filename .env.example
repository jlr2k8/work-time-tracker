# Trello API credentials
# Get your API key from: https://trello.com/app-key
# Generate a token by visiting: https://trello.com/1/authorize?expiration=never&scope=read&response_type=token&name=WorkTimeTracker&key=YOUR_API_KEY
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_API_TOKEN=your_trello_api_token_here
TRELLO_BOARD_ID=your_trello_board_id_here
TRELLO_MEMBER_ID=your_trello_member_id_here

# Billing
HOURLY_RATE=80.0
EXCLUDED_CARDS=

# Invoice Generator Settings
SENDER_NAME=Your Name
SENDER_ADDRESS=123 Main St, City, ST 12345
SENDER_PHONE=555-555-5555
SENDER_EMAIL=your.email@example.com
RECIPIENT_NAME=Client Name
INVOICE_PREFIX=INV